---

---

<section
    class="w-full py-25 relative"
    style="background-image: linear-gradient(to right, rgba(23, 21, 31, 0.07) 1px, transparent 1px), linear-gradient(to bottom, rgba(23, 21, 31, 0.07) 1px, transparent 1px); background-size: 22px 22px; background-color: #fff9e8;"
>
    <!-- Overlay to fade the grid -->
    <div
        class="absolute inset-0 bg-linear-to-b from-[#fff9e8] via-transparent to-[#fff9e8] pointer-events-none"
    >
    </div>

    <div class="w-[min(1180px,calc(100%-32px))] mx-auto relative z-10 px-4">
        <div>
            <h1
                class="font-black leading-[0.9] text-[clamp(2.8rem,8vw,6rem)] text-[#17151f] mb-8 tracking-tighter uppercase"
            >
                Master complex <br /> algorithms with <span
                    class="text-[#6d35ee]">precision.</span
                >
            </h1>

            <p
                class="text-lg md:text-2xl text-[#17151f] max-w-2xl mb-12 font-medium leading-tight opacity-90"
            >
                A premium engineering environment for project-based technical
                challenges. Solve, test, and optimize in a professional-grade
                workspace.
            </p>

            <div class="flex flex-wrap gap-5">
                <a
                    href="/problems"
                    class="inline-flex items-center justify-center min-h-14.5 px-10 bg-[#b9f35d] text-[#17151f] font-black text-xl border-2 border-[#17151f] rounded-lg shadow-[6px_6px_0_#17151f] hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-[4px_4px_0_#17151f] transition-all active:translate-x-1 active:translate-y-1 active:shadow-none uppercase"
                >
                    Start Solving
                </a>
            </div>
        </div>
    </div>
</section>
